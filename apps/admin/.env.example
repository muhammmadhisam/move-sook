# MoveSook Admin — environment variables
# All NEXT_PUBLIC_* values are inlined into the client bundle at build time.
# Copy to .env.local for dev; pass as --build-arg for Docker builds.
# Ports: `pnpm dev` serves on 9001 (Turbopack); `next start` / Docker on 3001.

# MoveSook API base URL (apps/api, default dev port 8787).
NEXT_PUBLIC_API_URL="http://localhost:8787"

# Google Maps JS API key — powers the live driver-tracking map on the job detail
# page. Without it the map shows a fallback notice. Use the same key as apps/web.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
