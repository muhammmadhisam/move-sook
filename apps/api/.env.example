# MoveSook API — environment variables
# Validated by apps/api/src/config.ts (Zod, fail-fast: missing required vars exit the process).
# In dev the API also loads the repo-root .env; values here override per-app.
# Ports: API serves on 8787; web/admin dev run on 9000/9001 (see WEB_ORIGIN/ADMIN_ORIGIN).

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8787

# Prisma datasource (packages/db). Local: docker compose up -d postgres
DATABASE_URL="postgresql://movesook:movesook@localhost:5432/movesook?schema=public"

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing secret (HS256), min 16 chars. Generate: openssl rand -base64 48
JWT_SECRET=""
# Separate cookie names so admin & user sessions never collide.
USER_COOKIE_NAME="ms_user_session"
ADMIN_COOKIE_NAME="ms_admin_session"
# Production only: set for cross-subdomain cookies, e.g. ".movesook.com"
# COOKIE_DOMAIN=""

# ── LINE ──────────────────────────────────────────────────────────────────────
# LINE Login channel ID (id_token audience check) — required.
LINE_CHANNEL_ID=""
# Optional: Messaging API access token. Absent = LINE push is a graceful no-op
# (only in-app notifications fire).
# LINE_CHANNEL_ACCESS_TOKEN=""
# Optional: channel secret. Set = POST /webhooks/line validates x-line-signature
# HMAC; absent = falls back to the x-system-key gate.
# LINE_CHANNEL_SECRET=""

# ── Service-to-service (webhooks/cron) ────────────────────────────────────────
# Static key for SYSTEM endpoints (x-system-key header), min 8 chars.
# Generate: openssl rand -hex 32
SYSTEM_API_KEY=""

# ── CORS origins ──────────────────────────────────────────────────────────────
WEB_ORIGIN="http://localhost:9000"
ADMIN_ORIGIN="http://localhost:9001"

# ── Cloudflare R2 uploads ─────────────────────────────────────────────────────
# Leave unset in dev → files go to local ./uploads. Set all four to use R2.
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="movesook-uploads"
# Optional: public bucket / custom domain — upload URLs then point straight at
# R2 instead of being proxied through GET /uploads/*.
# R2_PUBLIC_URL=""

# Redis — backs BullMQ (LINE-push queue + repeatable maintenance jobs) and the
# admin-login rate limiter. Required. `docker compose up -d redis` for local.
REDIS_URL="redis://localhost:6379"

# Run BullMQ workers (push + maintenance) in this process. Keep true for the
# all-in-one deploy; false on web-only replicas when workers run separately.
# Repeatable jobs are coordinated through Redis, so running workers on several
# instances is safe (each occurrence runs once).
WORKERS_ENABLED="true"
# Cron patterns (5-field) for the repeatable maintenance jobs, server tz.
# CRON_NUDGE_SCHEDULE="0 10 * * *"      # default: 10:00 daily
# CRON_EXPIRE_SCHEDULE="*/30 * * * *"   # default: every 30 minutes
