# MoveSook Web (customer + driver app) — environment variables
# All NEXT_PUBLIC_* values are inlined into the client bundle at build time.
# Copy to .env.local for dev; pass as --build-arg for Docker builds.
# Ports: `pnpm dev` serves on 9000 (Turbopack); `next start` / Docker on 3000.

# MoveSook API base URL (apps/api, default dev port 8787).
NEXT_PUBLIC_API_URL="http://localhost:8787"

# LINE LIFF app ID used on DESKTOP browsers (LINE Login channel). Endpoint /
# callback URL = <domain>/login.
NEXT_PUBLIC_LIFF_ID=""

# LINE MINI App LIFF ID used on MOBILE (Mini App channel; native login inside
# LINE). The web picks this on mobile and NEXT_PUBLIC_LIFF_ID on desktop.
# Both channels need the `openid` + `profile` scopes. API LINE_CHANNEL_ID must
# include BOTH channel ids (comma-separated) to verify tokens from either.
NEXT_PUBLIC_LIFF_ID_MINIAPP=""

# Google Maps JavaScript API key (route maps, live tracking).
# Restrict by HTTP referrer in the Google Cloud console — this key is public.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Canonical site URL (SEO: sitemap/robots/JSON-LD + OG tags).
# Dev = http://localhost:9000; production = the public domain, e.g. https://movesook.com
NEXT_PUBLIC_SITE_URL="http://localhost:9000"

# Google Search Console ownership token (URL-prefix property, HTML-tag method).
# Paste only the content value from the meta tag Search Console gives you.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
