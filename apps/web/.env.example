# MoveSook Web (customer + driver app) — environment variables
# All NEXT_PUBLIC_* values are inlined into the client bundle at build time.
# Copy to .env.local for dev; pass as --build-arg for Docker builds.

# MoveSook API base URL (apps/api, default dev port 8787).
NEXT_PUBLIC_API_URL="http://localhost:8787"

# LINE LIFF app ID (LINE Login for USER/DRIVER). The LIFF endpoint URL must
# point at /app (the marketing landing lives at /).
NEXT_PUBLIC_LIFF_ID=""

# Google Maps JavaScript API key (route maps, live tracking).
# Restrict by HTTP referrer in the Google Cloud console — this key is public.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Canonical site URL (SEO: sitemap/robots/JSON-LD).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
